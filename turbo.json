{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".astro/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^build"]
        },
        "typecheck": {
            "dependsOn": ["^build"]
        },
        "test:e2e": {
            "dependsOn": ["build"],
            "cache": false
        },
        "test": {
            "dependsOn": ["^build"],
            "cache": true
        },
        "clean": {
            "cache": false
        }
    }
}
