# Ever Works Minimal Directory Template — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Required ──────────────────────────────────────────────────

# URL of the Git data repository containing directory content
# Example: https://github.com/ever-works/awesome-react-components-data
DATA_REPOSITORY=

# ─── Optional ──────────────────────────────────────────────────

# GitHub Personal Access Token (required for private data repos)
GH_TOKEN=

# Git branch to clone from data repository (default: main)
GITHUB_BRANCH=main

# Local path to content directory (overrides DATA_REPOSITORY for dev)
# Example: /path/to/local/content
# CONTENT_PATH=

# Deployed site URL (used for sitemap and canonical links)
# Example: https://my-directory.vercel.app
SITE_URL=https://example.com

# ─── Content Sync & ISR ──────────────────────────────────────

# Set to 'false' to disable ISR and use pure static output (default: true)
# ENABLE_ISR=false

# Content cache TTL in milliseconds (default: 300000 = 5 minutes)
# Set to 0 for no TTL (build-time caching only)
# CONTENT_CACHE_TTL_MS=300000

# Polling interval in milliseconds (default: 0 = disabled)
# Set to e.g. 300000 for 5-minute polling
# SYNC_POLL_INTERVAL_MS=0

# Sync operation timeout in milliseconds (default: 60000 = 1 minute)
# SYNC_TIMEOUT_MS=60000

# Max retry attempts on sync failure (default: 3)
# SYNC_MAX_RETRIES=3

# GitHub webhook secret for HMAC-SHA256 validation
# Set this to the same secret configured in your GitHub webhook
# WEBHOOK_SECRET=

# Vercel Deploy Hook URL (used in static mode for triggering rebuilds)
# Create at: Vercel Project → Settings → Git → Deploy Hooks
# VERCEL_DEPLOY_HOOK_URL=
