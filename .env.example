# Ever Works Minimal Directory Template — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Required ──────────────────────────────────────────────────

# URL of the Git data repository containing directory content
# Example: https://github.com/ever-works/awesome-react-components-data
DATA_REPOSITORY=

# ─── Optional ──────────────────────────────────────────────────

# GitHub Personal Access Token (required for private data repos)
GH_TOKEN=

# Git branch to clone from data repository (default: main)
GITHUB_BRANCH=main

# Local path to content directory (overrides DATA_REPOSITORY for dev)
# Example: /path/to/local/content
# CONTENT_PATH=

# Deployed site URL (used for sitemap and canonical links)
# Example: https://my-directory.vercel.app
SITE_URL=https://example.com
