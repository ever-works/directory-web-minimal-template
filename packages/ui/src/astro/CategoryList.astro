---
/**
 * CategoryList — Headless category list component.
 * Renders a list of categories with optional item counts.
 * AI agents apply styling via class prop or data-* selectors.
 *
 * @example
 * ```astro
 * <CategoryList categories={categories} showCounts />
 * ```
 */
import type { CategoryListProps } from '../types.js';
import CategoryBadge from './CategoryBadge.astro';

type Props = CategoryListProps;

const { categories, showCounts = true, class: className, ...attrs } = Astro.props;
---

<nav class={className} data-component="category-list" aria-label="Categories" {...attrs}>
  <ul data-part="list">
    {categories.map((cat) => (
      <li data-part="list-item">
        <CategoryBadge
          category={cat}
          count={showCounts ? cat.count : undefined}
          href={`/category/${cat.id}`}
        />
      </li>
    ))}
  </ul>
</nav>
