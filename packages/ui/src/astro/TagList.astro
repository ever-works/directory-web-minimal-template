---
/**
 * TagList — Headless tag list component.
 * Renders a list of tags with optional item counts.
 * AI agents apply styling via class prop or data-* selectors.
 *
 * @example
 * ```astro
 * <TagList tags={tags} showCounts />
 * ```
 */
import type { TagListProps } from '../types.js';
import TagBadge from './TagBadge.astro';

type Props = TagListProps;

const { tags, showCounts = true, class: className, ...attrs } = Astro.props;
---

<nav class={className} data-component="tag-list" aria-label="Tags" {...attrs}>
  <ul data-part="list">
    {tags.map((tag) => (
      <li data-part="list-item">
        <TagBadge
          tag={tag}
          count={showCounts ? tag.count : undefined}
          href={`/tag/${tag.id}`}
        />
      </li>
    ))}
  </ul>
</nav>
