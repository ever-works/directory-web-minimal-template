---
/**
 * ItemList — Headless list layout for directory items.
 * Renders items in a vertical list with semantic HTML.
 * AI agents apply styling via class prop or data-* selectors.
 *
 * @example
 * ```astro
 * <ItemList items={items} />
 * ```
 */
import type { ItemListProps } from '../types.js';
import ItemCard from './ItemCard.astro';

type Props = ItemListProps;

const { items, class: className, ...attrs } = Astro.props;
---

<ul class={className} data-component="item-list" {...attrs}>
  {items.map((item) => (
    <li data-part="list-item">
      <ItemCard item={item} />
    </li>
  ))}
</ul>
