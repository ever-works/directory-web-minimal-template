---
/**
 * ItemList — Vertical list layout for directory items.
 *
 * @example
 * ```astro
 * <ItemList items={items} />
 * ```
 */
import type { ItemListProps } from '../types.js';
import ItemCard from './ItemCard.astro';

type Props = ItemListProps;

const { items, class: className, ...attrs } = Astro.props;
---

<ul class:list={["flex flex-col gap-4", className]} data-component="item-list" {...attrs}>
    {items.map((item) => (
        <li data-part="list-item">
            <ItemCard item={item} />
        </li>
    ))}
</ul>
