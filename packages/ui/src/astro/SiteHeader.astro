---
/**
 * SiteHeader — Site header/navigation using fulldev/ui Button for nav links.
 *
 * @example
 * ```astro
 * <SiteHeader config={siteConfig} nav={navItems} />
 * ```
 */
import type { SiteHeaderProps } from '../types.js';
import Button from '../primitives/button/Button.astro';

type Props = SiteHeaderProps;

const { config, nav = [], class: className, ...attrs } = Astro.props;

const logoSrc = config.logo?.logo_image;
const logoSrcDark = config.logo?.logo_image_dark;
---

<a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:rounded-md focus:bg-background focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-foreground focus:shadow-lg focus:ring-2 focus:ring-ring focus:outline-none"
    data-component="skip-to-content"
>
    Skip to content
</a>

<header
    class:list={["sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur-lg", className]}
    data-component="site-header"
    {...attrs}
>
    <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <div data-part="branding">
            <a href="/" data-part="logo-link" aria-label={`${config.company_name} home`} class="flex items-center gap-2 font-semibold text-foreground">
                {logoSrc ? (
                    <>
                        <img src={logoSrc} alt={config.company_name} data-part="logo" data-theme="light" loading="lazy" class="h-6" />
                        {logoSrcDark && (
                            <img src={logoSrcDark} alt={config.company_name} data-part="logo" data-theme="dark" loading="lazy" class="h-6" />
                        )}
                    </>
                ) : (
                    <span data-part="site-name">{config.company_name}</span>
                )}
            </a>
        </div>

        {nav.length > 0 && (
            <nav data-part="nav" aria-label="Main navigation" class="hidden md:block">
                <ul data-part="nav-list" class="flex items-center gap-1">
                    {nav.map((item) => (
                        <li data-part="nav-item" data-active={item.isActive ? '' : undefined}>
                            <Button
                                as="a"
                                href={item.href}
                                variant="ghost"
                                size="sm"
                                data-part="nav-link"
                                aria-current={item.isActive ? 'page' : undefined}
                            >
                                {item.label}
                            </Button>
                        </li>
                    ))}
                </ul>
            </nav>
        )}

        <div data-part="actions" class="flex items-center gap-2">
            <slot />
        </div>
    </div>
</header>
