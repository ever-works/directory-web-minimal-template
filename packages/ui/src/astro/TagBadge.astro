---
/**
 * TagBadge — Directory-specific wrapper around fulldev/ui Badge.
 * Renders a tag label with optional count and link.
 *
 * @example
 * ```astro
 * <TagBadge tag={tag} count={5} href="/tag/open-source" />
 * ```
 */
import type { TagBadgeProps } from '../types.js';
import Badge from '../primitives/badge/Badge.astro';

type Props = TagBadgeProps;

const { tag, count, href, class: className, ...attrs } = Astro.props;
---

{href ? (
    <Badge
        as="a"
        href={href}
        variant="secondary"
        class={className}
        data-component="tag-badge"
        {...attrs}
    >
        <span data-part="name">{tag.name}</span>
        {count !== undefined && <span data-part="count">{count}</span>}
    </Badge>
) : (
    <Badge
        variant="secondary"
        class={className}
        data-component="tag-badge"
        {...attrs}
    >
        <span data-part="name">{tag.name}</span>
        {count !== undefined && <span data-part="count">{count}</span>}
    </Badge>
)}
