{
    "name": "@ever-works/ui",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./lib/utils": "./src/lib/utils.ts",
        "./lib/sort-items": "./src/lib/sort-items.ts",
        "./lib/keyboard": "./src/lib/keyboard.ts",
        "./lib/pagination": "./src/lib/pagination.ts",
        "./primitives/*": "./src/primitives/*",
        "./astro/*": "./src/astro/*",
        "./preact/SearchInput": "./src/preact/SearchInput.tsx",
        "./preact/FilterBar": "./src/preact/FilterBar.tsx",
        "./preact/SortSelect": "./src/preact/SortSelect.tsx",
        "./preact/BackToTop": "./src/preact/BackToTop.tsx",
        "./preact/ThemeToggle": "./src/preact/ThemeToggle.tsx",
        "./preact/LayoutSwitcher": "./src/preact/LayoutSwitcher.tsx",
        "./preact/ItemBrowser": "./src/preact/ItemBrowser.tsx",
        "./preact/MobileMenu": "./src/preact/MobileMenu.tsx"
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "test": "vitest run",
        "test:safe": "tsx scripts/test-per-file.ts",
        "clean": "rm -rf dist",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@ever-works/core": "workspace:*",
        "@ever-works/plugin-analytics": "workspace:*",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.5.0"
    },
    "peerDependencies": {
        "astro": "^6.1.9",
        "preact": "^10.0.0"
    },
    "devDependencies": {
        "@ever-works/eslint-config": "workspace:*",
        "@ever-works/tsconfig": "workspace:*",
        "@testing-library/preact": "^3.2.4",
        "@types/node": "^25.6.0",
        "astro": "^6.1.9",
        "jsdom": "^29.0.2",
        "preact": "^10.29.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
