{
    "name": "@ever-works/ui",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./lib/utils": "./src/lib/utils.ts",
        "./lib/sort-items": "./src/lib/sort-items.ts",
        "./lib/keyboard": "./src/lib/keyboard.ts",
        "./lib/pagination": "./src/lib/pagination.ts",
        "./primitives/*": "./src/primitives/*",
        "./astro/*": "./src/astro/*",
        "./preact/SearchInput": "./src/preact/SearchInput.tsx",
        "./preact/FilterBar": "./src/preact/FilterBar.tsx",
        "./preact/SortSelect": "./src/preact/SortSelect.tsx",
        "./preact/BackToTop": "./src/preact/BackToTop.tsx",
        "./preact/ThemeToggle": "./src/preact/ThemeToggle.tsx",
        "./preact/LayoutSwitcher": "./src/preact/LayoutSwitcher.tsx",
        "./preact/ItemBrowser": "./src/preact/ItemBrowser.tsx",
        "./preact/MobileMenu": "./src/preact/MobileMenu.tsx"
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "typecheck:ct": "tsc --noEmit --project tsconfig.ct.json",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "test": "vitest run",
        "test:safe": "tsx scripts/test-per-file.ts",
        "test:ct": "playwright test --config=playwright.ct.config.ts",
        "test:ct:install": "playwright install --with-deps chromium",
        "clean": "rm -rf dist",
        "test:coverage": "vitest run --coverage",
        "coverage": "pnpm test:coverage && pnpm test:ct && tsx scripts/coverage-merge.ts"
    },
    "dependencies": {
        "@ever-works/core": "workspace:*",
        "@ever-works/plugin-analytics": "workspace:*",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.5.0"
    },
    "peerDependencies": {
        "astro": "^6.1.9",
        "preact": "^10.0.0"
    },
    "devDependencies": {
        "@ever-works/eslint-config": "workspace:*",
        "@ever-works/tsconfig": "workspace:*",
        "@playwright/experimental-ct-react": "^1.59.1",
        "@playwright/test": "^1.59.1",
        "@testing-library/preact": "^3.2.4",
        "@types/node": "^25.6.0",
        "astro": "^6.1.9",
        "jsdom": "^29.0.2",
        "monocart-coverage-reports": "^2.12.9",
        "monocart-reporter": "^2.10.0",
        "preact": "^10.29.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5",
        "vitest-monocart-coverage": "^4.0.2"
    }
}
