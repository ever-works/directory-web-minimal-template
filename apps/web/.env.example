# Ever Works Minimal Template — Web App Environment Variables
# Copy to .env and fill in your values.
# See also: ../../.env.example for the full reference.

# URL of the Git data repository containing directory content
DATA_REPOSITORY=

# GitHub PAT (required for private data repos)
GH_TOKEN=

# Git branch (default: main)
GITHUB_BRANCH=main

# Local content path (overrides DATA_REPOSITORY for dev)
# CONTENT_PATH=../../apps/sample-basic/.content

# Site URL for sitemap and canonical links
SITE_URL=https://example.com
