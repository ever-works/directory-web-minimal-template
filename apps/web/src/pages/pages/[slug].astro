---
/**
 * Static Page — Renders a markdown page from `.content/pages/<slug>.md`.
 *
 * Uses getStaticPaths to generate one page per content page at build time.
 * Pages are standalone content like "About", "Privacy Policy", etc.
 * Includes Article JSON-LD structured data for SEO.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../lib/content';
import { generateJsonLd } from '@ever-works/plugin-seo';
import type { PageData } from '@ever-works/core';
import Breadcrumbs from '@ever-works/ui/astro/Breadcrumbs.astro';

export async function getStaticPaths() {
    const { pages } = await getContent();
    return pages.map((page) => ({
        params: { slug: page.slug },
        props: { page },
    }));
}

interface Props {
    page: PageData;
}

const { page } = Astro.props;
const { config } = await getContent();

const siteUrl = config.site_url ?? '';

// Article JSON-LD for static content pages
const articleLd = generateJsonLd('Article', {
    type: 'Article',
    headline: page.title,
    url: `${siteUrl}/pages/${page.slug}`,
    description: page.description,
    author: config.company_name,
});

// BreadcrumbList JSON-LD
const breadcrumbLd = generateJsonLd('BreadcrumbList', {
    type: 'BreadcrumbList',
    items: [
        { name: 'Home', url: `${siteUrl}/` },
        { name: page.title, url: `${siteUrl}/pages/${page.slug}` },
    ],
});

const breadcrumbItems = [
    { label: 'Home', href: '/' },
    { label: page.title },
];
---

<BaseLayout
    title={page.title}
    description={page.description}
    config={config}
    pageType="article"
    markdownMirrorUrl={`/pages/${page.slug}.md`}
>
    <Fragment slot="head">
        <script is:inline type="application/ld+json" set:html={articleLd} />
        <script is:inline type="application/ld+json" set:html={breadcrumbLd} />
    </Fragment>

    <Breadcrumbs items={breadcrumbItems} />

    <article class="prose max-w-none">
        <h1>{page.title}</h1>
        {page.description && <p class="lead">{page.description}</p>}
        <Fragment set:html={page.content} />
    </article>
</BaseLayout>
