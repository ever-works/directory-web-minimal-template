---
/**
 * Comparison Page — Side-by-side comparison of two directory items.
 *
 * Uses getStaticPaths to generate one page per comparison at build time.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../lib/content';
import { generateJsonLd } from '@ever-works/plugin-seo';
import Breadcrumbs from '@ever-works/ui/astro/Breadcrumbs.astro';
import ComparisonTable from '@ever-works/ui/astro/ComparisonTable.astro';

export async function getStaticPaths() {
    const { comparisons } = await getContent();
    return comparisons.map((comp) => ({
        params: { slug: comp.slug },
        props: { comparison: comp },
    }));
}

const { comparison } = Astro.props;
const { config } = await getContent();

const breadcrumbItems = [
    { label: 'Home', href: '/' },
    { label: 'Comparisons', href: '/comparisons' },
    { label: comparison.title },
];

const siteUrl = (config.app_url ?? '').replace(/\/$/, '');

// JSON-LD ItemList for comparison contestants
const jsonLd = generateJsonLd('ItemList', {
    type: 'ItemList',
    items: [
        { name: comparison.item_a_name, url: `/item/${comparison.item_a_slug}` },
        { name: comparison.item_b_name, url: `/item/${comparison.item_b_slug}` },
    ],
});

// BreadcrumbList JSON-LD: Home → Comparisons → <title>
const breadcrumbLd = generateJsonLd('BreadcrumbList', {
    type: 'BreadcrumbList',
    items: [
        { name: 'Home', url: `${siteUrl}/` },
        { name: 'Comparisons', url: `${siteUrl}/comparisons` },
        { name: comparison.title, url: `${siteUrl}/comparison/${comparison.slug}` },
    ],
});
---

<BaseLayout
    title={comparison.title}
    description={comparison.summary || `Compare ${comparison.item_a_name} vs ${comparison.item_b_name}`}
    config={config}
    markdownMirrorUrl={`/comparison/${comparison.slug}.md`}
>
    <Fragment slot="head">
        <script is:inline type="application/ld+json" set:html={jsonLd} />
        <script is:inline type="application/ld+json" set:html={breadcrumbLd} />
    </Fragment>
    <Breadcrumbs items={breadcrumbItems} />

    <ComparisonTable comparison={comparison} showScores />
</BaseLayout>
