---
/**
 * Collections Index Page — Lists all active collections.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';

const { collections, config } = await getContent();
const activeCollections = collections.filter((c) => c.isActive !== false);
---

<BaseLayout title="Collections" config={config}>
    <nav data-component="breadcrumbs">
        <a href="/">Home</a>
        <span data-part="separator">/</span>
        <span data-part="current">Collections</span>
    </nav>

    <section data-component="collections-page">
        <h1 data-part="heading">Collections</h1>

        {activeCollections.length === 0 ? (
            <p data-component="empty-state">No collections available.</p>
        ) : (
            <div data-part="grid">
                {activeCollections.map((collection) => (
                    <article data-component="collection-card">
                        {collection.icon_url && (
                            <span data-part="icon">{collection.icon_url}</span>
                        )}
                        <h2 data-part="name">
                            <a href={`/collection/${collection.slug}`}>{collection.name}</a>
                        </h2>
                        {collection.description && (
                            <p data-part="description">{collection.description}</p>
                        )}
                        {collection.items && (
                            <span data-part="item-count">
                                {collection.items.length} {collection.items.length === 1 ? config.item_name : config.items_name}
                            </span>
                        )}
                    </article>
                ))}
            </div>
        )}
    </section>
</BaseLayout>
