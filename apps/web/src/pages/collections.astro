---
/**
 * Collections Index Page — Lists all active collections.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';
import Breadcrumbs from '@ever-works/ui/astro/Breadcrumbs.astro';
import CollectionCard from '@ever-works/ui/astro/CollectionCard.astro';
import EmptyState from '@ever-works/ui/astro/EmptyState.astro';

const { collections, config } = await getContent();
const activeCollections = collections.filter((c) => c.isActive !== false);
---

<BaseLayout title="Collections" config={config}>
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Collections' }]} />

    <section data-component="collections-page">
        <h1 data-part="heading">Collections</h1>

        {activeCollections.length === 0 ? (
            <EmptyState message="No collections available." />
        ) : (
            <div data-part="grid" role="list">
                {activeCollections.map((collection) => (
                    <div role="listitem">
                        <CollectionCard
                            collection={collection}
                            itemCount={collection.items?.length}
                        />
                    </div>
                ))}
            </div>
        )}
    </section>
</BaseLayout>
