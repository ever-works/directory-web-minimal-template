---
/**
 * Tags Index Page — Lists all active tags with item counts.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';
import Breadcrumbs from '@ever-works/ui/astro/Breadcrumbs.astro';
import TagList from '@ever-works/ui/astro/TagList.astro';
import EmptyState from '@ever-works/ui/astro/EmptyState.astro';

const { tags, config } = await getContent();

const breadcrumbItems = [
    { label: 'Home', href: '/' },
    { label: 'Tags' },
];
---

<BaseLayout title="Tags" config={config}>
    <Breadcrumbs items={breadcrumbItems} />

    <section data-component="tags-page">
        <h1 data-part="heading">Tags</h1>

        {tags.length === 0 ? (
            <EmptyState message="No tags defined." />
        ) : (
            <TagList tags={tags} showCounts />
        )}
    </section>
</BaseLayout>
