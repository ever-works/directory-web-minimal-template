---
/**
 * Categories Index Page — Lists all categories with item counts.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';
import Breadcrumbs from '@ever-works/ui/astro/Breadcrumbs.astro';
import CategoryList from '@ever-works/ui/astro/CategoryList.astro';
import EmptyState from '@ever-works/ui/astro/EmptyState.astro';

const { categories, config } = await getContent();

const breadcrumbItems = [
    { label: 'Home', href: '/' },
    { label: 'Categories' },
];
---

<BaseLayout title="Categories" config={config}>
    <Breadcrumbs items={breadcrumbItems} />

    <section data-component="categories-page">
        <h1 data-part="heading">Categories</h1>

        {categories.length === 0 ? (
            <EmptyState message="No categories defined." />
        ) : (
            <CategoryList categories={categories} showCounts />
        )}
    </section>
</BaseLayout>
