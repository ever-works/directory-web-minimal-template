---
/**
 * Tag Page — Lists all items with a specific tag.
 *
 * Uses getStaticPaths to generate one page per active tag at build time.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../lib/content';
import { generateJsonLd } from '@ever-works/plugin-seo';
import Breadcrumbs from '@ever-works/ui/astro/Breadcrumbs.astro';
import ItemGrid from '@ever-works/ui/astro/ItemGrid.astro';
import EmptyState from '@ever-works/ui/astro/EmptyState.astro';

export async function getStaticPaths() {
    const { tags } = await getContent();
    return tags.map((tag) => ({
        params: { slug: tag.id },
        props: { tag },
    }));
}

const { tag } = Astro.props;
const { items, config } = await getContent();

// Filter items by this tag
const tagItems = items.filter((item) =>
    item.tags?.includes(tag.id)
);

const breadcrumbItems = [
    { label: 'Home', href: '/' },
    { label: 'Tags', href: '/tags' },
    { label: tag.name },
];

// JSON-LD ItemList for tag listing
const jsonLd = tagItems.length > 0
    ? generateJsonLd('ItemList', {
        type: 'ItemList',
        items: tagItems.map((item) => ({
            name: item.name,
            url: `/item/${item.slug}`,
        })),
    })
    : null;
---

<BaseLayout
    title={tag.name}
    description={`Browse ${tagItems.length} ${config.items_name.toLowerCase()} tagged with ${tag.name}`}
    config={config}
>
    {jsonLd && (
        <Fragment slot="head">
            <script is:inline type="application/ld+json" set:html={jsonLd} />
        </Fragment>
    )}
    <Breadcrumbs items={breadcrumbItems} />

    <section data-component="tag-page">
        <h1 data-part="heading">{tag.name}</h1>
        <p data-part="count">{tagItems.length} {tagItems.length === 1 ? config.item_name : config.items_name}</p>

        {tagItems.length === 0 ? (
            <EmptyState message={`No ${config.items_name.toLowerCase()} with this tag.`} />
        ) : (
            <ItemGrid items={tagItems} columns={3} />
        )}
    </section>
</BaseLayout>
