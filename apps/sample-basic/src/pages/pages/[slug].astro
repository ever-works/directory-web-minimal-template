---
/**
 * Static Page — Renders a markdown page from `.content/pages/<slug>.md`.
 *
 * Uses getStaticPaths to generate one page per content page at build time.
 * Pages are standalone content like "About", "Privacy Policy", etc.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../lib/content';
import { generateJsonLd } from '@ever-works/plugin-seo';
import type { PageData } from '@ever-works/core';

export async function getStaticPaths() {
    const { pages } = await getContent();
    return pages.map((page) => ({
        params: { slug: page.slug },
        props: { page },
    }));
}

interface Props {
    page: PageData;
}

const { page } = Astro.props;
const { config } = await getContent();

const siteUrl = config.site_url ?? '';

const articleLd = generateJsonLd('Article', {
    type: 'Article',
    headline: page.title,
    url: `${siteUrl}/pages/${page.slug}`,
    description: page.description,
    author: config.company_name,
});
---

<BaseLayout
    title={page.title}
    description={page.description}
    config={config}
    pageType="article"
>
    <Fragment slot="head">
        <script is:inline type="application/ld+json" set:html={articleLd} />
    </Fragment>

    <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-gray-700">Home</a>
        <span class="mx-2">/</span>
        <span>{page.title}</span>
    </nav>

    <article class="prose prose-lg max-w-none dark:prose-invert">
        <h1 class="text-3xl font-bold mb-4">{page.title}</h1>
        {page.description && <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">{page.description}</p>}
        <Fragment set:html={page.content} />
    </article>
</BaseLayout>
