---
/**
 * Home Page — React UI Components Directory
 *
 * Hero section, category grid, and featured component libraries.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';
import { paginate } from '@ever-works/plugin-pagination';
import { generateJsonLd } from '@ever-works/plugin-seo';

const { items, categories, config } = await getContent();
const perPage = config.pagination?.itemsPerPage ?? 12;
const pagination = paginate(items, { page: 1, perPage });
const featuredItems = items.filter((i) => i.featured);

const jsonLd = generateJsonLd('WebSite', {
    type: 'WebSite',
    name: config.company_name,
    url: config.app_url ?? '',
});
---

<BaseLayout title="Home" config={config}>
    <Fragment slot="head">
        <script is:inline type="application/ld+json" set:html={jsonLd} />
    </Fragment>

    <!-- Hero -->
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 px-6 py-16 text-center text-white sm:px-12 sm:py-24 mb-12">
        <div class="relative z-10">
            <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
                {config.company_name}
            </h1>
            <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-100 sm:text-xl">
                Discover and compare {items.length} {items.length === 1 ? config.item_name.toLowerCase() : config.items_name.toLowerCase()} for your next project.
            </p>
        </div>
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30" />
    </section>

    <!-- Categories -->
    {categories.length > 0 && (
        <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Categories</h2>
            <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
                {categories.map((cat) => (
                    <a
                        href={`/category/${cat.id}`}
                        class="group flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:border-brand-300 hover:shadow-md dark:border-gray-700 dark:bg-gray-900 dark:hover:border-brand-600"
                    >
                        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-950 dark:text-brand-400 group-hover:bg-brand-100 dark:group-hover:bg-brand-900 transition-colors">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                            </svg>
                        </div>
                        <div>
                            <span class="text-sm font-semibold text-gray-900 dark:text-white">{cat.name}</span>
                            <span class="block text-xs text-gray-500 dark:text-gray-400">{cat.count} {cat.count === 1 ? 'library' : 'libraries'}</span>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    )}

    <!-- Featured -->
    {featuredItems.length > 0 && (
        <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Featured</h2>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {featuredItems.map((item) => (
                    <a
                        href={`/item/${item.slug}`}
                        class="group relative rounded-xl border border-brand-200 bg-brand-50/50 p-6 transition-all hover:border-brand-300 hover:shadow-lg dark:border-brand-800 dark:bg-brand-950/30 dark:hover:border-brand-700"
                    >
                        <div class="absolute right-4 top-4">
                            <span class="inline-flex items-center rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-medium text-brand-700 dark:bg-brand-900 dark:text-brand-300">
                                Featured
                            </span>
                        </div>
                        <div class="flex items-start gap-4">
                            {item.icon_url && (
                                <img src={item.icon_url} alt="" class="h-12 w-12 rounded-lg object-contain" loading="lazy" />
                            )}
                            <div class="min-w-0">
                                <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                                    {item.name}
                                </h3>
                                {item.description && (
                                    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">{item.description}</p>
                                )}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    )}

    <!-- All Items -->
    <section>
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">All {config.items_name}</h2>
            <span class="text-sm text-gray-500 dark:text-gray-400">{items.length} total</span>
        </div>

        {pagination.items.length === 0 ? (
            <div class="rounded-xl border-2 border-dashed border-gray-300 p-12 text-center dark:border-gray-700">
                <p class="text-gray-500 dark:text-gray-400">No {config.items_name.toLowerCase()} found.</p>
            </div>
        ) : (
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {pagination.items.map((item) => (
                    <a
                        href={`/item/${item.slug}`}
                        class="group flex items-start gap-4 rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-gray-300 hover:shadow-md dark:border-gray-700 dark:bg-gray-900 dark:hover:border-gray-600"
                    >
                        {item.icon_url && (
                            <img src={item.icon_url} alt="" class="h-10 w-10 shrink-0 rounded-lg object-contain" loading="lazy" />
                        )}
                        <div class="min-w-0">
                            <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                                {item.name}
                            </h3>
                            {item.description && (
                                <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">{item.description}</p>
                            )}
                            <div class="mt-2 flex flex-wrap gap-1">
                                {item.tags?.slice(0, 3).map((tag) => (
                                    <span class="inline-block rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        )}

        {pagination.hasNext && (
            <div class="mt-8 flex justify-center">
                <a href="/page/2" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-6 py-3 text-sm font-medium text-white shadow-sm hover:bg-brand-700 transition-colors">
                    Next page
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                </a>
            </div>
        )}
    </section>
</BaseLayout>
