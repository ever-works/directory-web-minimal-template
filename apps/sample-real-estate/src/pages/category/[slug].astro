---
/**
 * Category Page — Lists all properties in a specific category.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { getContent } from '../../lib/content';
import { generateJsonLd } from '@ever-works/plugin-seo';
import type { ItemData, CategoryData } from '@ever-works/core';

export async function getStaticPaths() {
    const { categories, items } = await getContent();
    return categories.map((cat) => {
        const categoryItems = items.filter((item) => {
            const cats = Array.isArray(item.category) ? item.category : [item.category];
            return cats.includes(cat.id);
        });
        return {
            params: { slug: cat.id },
            props: { category: cat, items: categoryItems },
        };
    });
}

interface Props {
    category: CategoryData;
    items: ItemData[];
}

const { category, items } = Astro.props;
const { config } = await getContent();

// JSON-LD ItemList for category listing
const jsonLd = items.length > 0
    ? generateJsonLd('ItemList', {
        type: 'ItemList',
        items: items.map((item) => ({
            name: item.name,
            url: `/item/${item.slug}`,
        })),
    })
    : null;
---

<BaseLayout title={category.name} description={`Browse ${items.length} ${config.items_name.toLowerCase()} in ${category.name}`} config={config}>
    {jsonLd && (
        <Fragment slot="head">
            <script is:inline type="application/ld+json" set:html={jsonLd} />
        </Fragment>
    )}
    <BreadcrumbNav path={Astro.url.pathname} />

    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{category.name}</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">{items.length} {items.length === 1 ? config.item_name.toLowerCase() : config.items_name.toLowerCase()}</p>
    </div>

    {items.length === 0 ? (
        <div class="rounded-xl border-2 border-dashed border-gray-300 p-12 text-center dark:border-gray-700">
            <p class="text-gray-500 dark:text-gray-400">No {config.items_name.toLowerCase()} in this category yet.</p>
        </div>
    ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((item) => (
                <a
                    href={`/item/${item.slug}`}
                    class="group flex items-start gap-4 rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-gray-300 hover:shadow-md dark:border-gray-700 dark:bg-gray-900 dark:hover:border-gray-600"
                >
                    <div class="min-w-0">
                        <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{item.name}</h3>
                        {item.description && (
                            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">{item.description}</p>
                        )}
                        <div class="mt-2 flex flex-wrap gap-1">
                            {item.tags?.slice(0, 3).map((tag) => (
                                <span class="inline-block rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-400">{tag}</span>
                            ))}
                        </div>
                    </div>
                </a>
            ))}
        </div>
    )}
</BaseLayout>
