---
/**
 * Breadcrumb navigation component.
 *
 * Uses the breadcrumbs plugin data (from `_breadcrumbs` on ContentData)
 * to render a consistent breadcrumb trail for any page path.
 *
 * Usage:
 * ```astro
 * <BreadcrumbNav path={Astro.url.pathname} />
 * ```
 */
import { getContent } from '../lib/content';
import type { BreadcrumbEntry } from '@ever-works/plugin-breadcrumbs';

interface Props {
    /** The current page pathname (e.g., '/category/form-components') */
    path: string;
}

const { path } = Astro.props;
const data = await getContent();

// Access breadcrumbs generated by the plugin (attached as _breadcrumbs)
const breadcrumbMap = (data as unknown as Record<string, unknown>)._breadcrumbs as
    | Map<string, BreadcrumbEntry[]>
    | undefined;

// Strip trailing slash for lookup (except root '/')
const normalizedPath = path === '/' ? '/' : path.replace(/\/$/, '');
const crumbs = breadcrumbMap?.get(normalizedPath) ?? [];
---

{crumbs.length > 0 && (
    <nav
        class="mb-6 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400"
        aria-label="Breadcrumb"
        data-component="breadcrumb-nav"
    >
        {crumbs.map((crumb, i) => (
            <>
                {i > 0 && (
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                )}
                {crumb.href ? (
                    <a
                        href={crumb.href}
                        class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
                        data-part="breadcrumb-link"
                    >
                        {crumb.label}
                    </a>
                ) : (
                    <span
                        class="text-gray-900 dark:text-white font-medium"
                        data-part="breadcrumb-current"
                        aria-current="page"
                    >
                        {crumb.label}
                    </span>
                )}
            </>
        ))}
    </nav>
)}
