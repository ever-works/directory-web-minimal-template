---
/**
 * Home Page — Time Tracking Directory (Git Data)
 *
 * Thin hero banner and a single interactive ItemBrowser Preact island
 * that includes collapsible categories/tags, search, sort, and pagination.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';
import { generateJsonLd } from '@ever-works/plugin-seo';
import ItemBrowser from '../components/ItemBrowser';

const { items, categories, tags, config } = await getContent();

const jsonLd = generateJsonLd('WebSite', {
    type: 'WebSite',
    name: config.company_name,
    url: config.app_url ?? '',
});

// Serialize items for the Preact island (only needed fields)
const browserItems = items.map((item) => ({
    slug: item.slug,
    name: item.name,
    description: item.description,
    category: item.category,
    tags: item.tags,
    featured: item.featured,
    icon_url: item.icon_url,
    updated_at: item.updated_at,
}));

// Filter out categories and tags with no items, include counts
const activeCategories = categories
    .filter((cat) => cat.count > 0)
    .map((cat) => ({ id: cat.id, name: cat.name, count: cat.count }));

const activeTags = tags
    .filter((tag) => tag.count > 0)
    .map((tag) => ({ id: tag.id, name: tag.name, count: tag.count }));
---

<BaseLayout title="Home" config={config}>
    <Fragment slot="head">
        <script is:inline type="application/ld+json" set:html={jsonLd} />
    </Fragment>

    <!-- Hero -->
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 px-6 py-4 text-center text-white sm:px-10 sm:py-5 mb-10">
        <div class="relative z-10">
            <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl lg:text-4xl">
                Ever Works Demo
            </h1>
            <p class="mx-auto mt-2 max-w-2xl text-sm text-brand-100 sm:text-base">
                Discover and compare {items.length} {items.length === 1 ? config.item_name.toLowerCase() : config.items_name.toLowerCase()} for your next project.
            </p>
        </div>
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30" />
    </section>

    <!-- Single interactive island: categories, tags, search, sort, items, pagination -->
    <ItemBrowser
        client:load
        items={browserItems}
        categories={activeCategories}
        tags={activeTags}
        itemsName={config.items_name}
        perPage={12}
    />
</BaseLayout>
