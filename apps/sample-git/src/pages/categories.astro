---
/**
 * Categories Index — Overview of all categories.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';

const { categories: allCategories, config } = await getContent();
const categories = allCategories.filter((cat) => cat.count > 0);
---

<BaseLayout title="Categories" description={`Browse all categories of ${config.items_name.toLowerCase()}`} config={config}>
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Categories</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">Browse {config.items_name.toLowerCase()} by category</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((cat) => (
            <a
                href={`/category/${cat.id}`}
                class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:border-brand-300 hover:shadow-md dark:border-gray-700 dark:bg-gray-900 dark:hover:border-brand-600"
            >
                <div class="flex items-center gap-4">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-950 dark:text-brand-400 group-hover:bg-brand-100 dark:group-hover:bg-brand-900 transition-colors">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{cat.name}</h2>
                        <p class="text-sm text-gray-500 dark:text-gray-400">{cat.count} {cat.count === 1 ? 'item' : 'items'}</p>
                    </div>
                </div>
            </a>
        ))}
    </div>
</BaseLayout>
