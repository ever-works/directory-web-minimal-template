---
/**
 * Home Page — Tech Events Directory
 *
 * Hero section, category grid, featured events, and interactive item browser.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';
import { generateJsonLd } from '@ever-works/plugin-seo';
import ItemBrowser from '../components/ItemBrowser';

const { items, categories, tags, config } = await getContent();
const featuredItems = items.filter((i) => i.featured);

const jsonLd = generateJsonLd('WebSite', {
    type: 'WebSite',
    name: config.company_name,
    url: config.app_url ?? '',
});

// Serialize items for the Preact island (only needed fields)
const browserItems = items.map((item) => ({
    slug: item.slug,
    name: item.name,
    description: item.description,
    category: item.category,
    tags: item.tags,
    featured: item.featured,
    icon_url: item.icon_url,
    updated_at: item.updated_at,
}));
const totalItemCount = items.length;

const browserCategories = categories.map((cat) => ({
    id: cat.id,
    name: cat.name,
}));

const browserTags = tags.map((tag) => ({
    id: tag.id,
    name: tag.name,
}));

// Helper to extract event-specific meta location for featured cards
function getMetaLocation(item: typeof items[number]): string | undefined {
    const m = (typeof item.meta === 'object' && item.meta !== null ? item.meta : undefined) as Record<string, string> | undefined;
    return m?.location;
}
---

<BaseLayout title="Home" config={config}>
    <Fragment slot="head">
        <script is:inline type="application/ld+json" set:html={jsonLd} />
    </Fragment>

    <!-- Hero -->
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 px-6 py-16 text-center text-white sm:px-12 sm:py-24 mb-12">
        <div class="relative z-10">
            <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
                {config.company_name}
            </h1>
            <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-100 sm:text-xl">
                Discover conferences, meetups, workshops, and hackathons for developers.
            </p>
        </div>
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30" />
    </section>

    <!-- Categories -->
    {categories.length > 0 && (
        <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Categories</h2>
            <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
                {categories.map((cat) => (
                    <a
                        href={`/category/${cat.id}`}
                        class="group flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:border-brand-300 hover:shadow-md dark:border-gray-700 dark:bg-gray-900 dark:hover:border-brand-600"
                    >
                        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-950 dark:text-brand-400 group-hover:bg-brand-100 dark:group-hover:bg-brand-900 transition-colors">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                            </svg>
                        </div>
                        <div>
                            <span class="text-sm font-semibold text-gray-900 dark:text-white">{cat.name}</span>
                            <span class="block text-xs text-gray-500 dark:text-gray-400">{cat.count} {cat.count === 1 ? 'event' : 'events'}</span>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    )}

    <!-- Featured Events -->
    {featuredItems.length > 0 && (
        <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Featured Events</h2>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                {featuredItems.map((item) => (
                    <a
                        href={`/item/${item.slug}`}
                        class="group relative rounded-xl border border-brand-200 bg-brand-50/50 p-6 transition-all hover:border-brand-300 hover:shadow-lg dark:border-brand-800 dark:bg-brand-950/30 dark:hover:border-brand-700"
                    >
                        <div class="absolute right-4 top-4">
                            <span class="inline-flex items-center rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-medium text-brand-700 dark:bg-brand-900 dark:text-brand-300">
                                Featured
                            </span>
                        </div>
                        <div class="min-w-0">
                            <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                                {item.name}
                            </h3>
                            {item.description && (
                                <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">{item.description}</p>
                            )}
                            {getMetaLocation(item) && (
                                <p class="mt-2 text-xs text-gray-500 dark:text-gray-500">
                                    {getMetaLocation(item)}
                                </p>
                            )}
                        </div>
                    </a>
                ))}
            </div>
        </section>
    )}

    <!-- Interactive Item Browser (Preact island with search, filter, sort) -->
    <section>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
            Browse All {config.items_name}
        </h2>
        <ItemBrowser
            client:load
            initialItems={browserItems}
            totalItemCount={totalItemCount}
            categories={browserCategories}
            tags={browserTags}
            itemsName={config.items_name}
        />
    </section>
</BaseLayout>
